<Window x:Class="DriveVision.ScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DriveVision - Scansione" Height="250" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#1e1e1e" 
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" BorderBrush="#333333" BorderThickness="1">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock x:Name="TxtIcona" FontFamily="Segoe UI Emoji" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtTitolo" Text="Analisi in corso" Foreground="#deff9a" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

            <TextBlock x:Name="TxtStato" Text="Preparazione motore" Foreground="#ffffff" FontSize="14" HorizontalAlignment="Center" Margin="0,10,0,25"/>

            <ProgressBar IsIndeterminate="True" Width="300" Height="4" Foreground="#00a8ff" Background="#333333" BorderThickness="0"/>

        </StackPanel>
    </Grid>
</Window>