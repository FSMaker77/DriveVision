<Window x:Class="DriveVision.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info su DriveVision" Width="480" SizeToContent="Height" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="#1e1e1e" Foreground="#eeeeee" ShowInTaskbar="False"
        Padding="0,0,0,10">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="DriveVision Release 1.0" FontSize="22" FontWeight="Bold" Foreground="#deff9a" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtDescrizione" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock x:Name="TxtSviluppatore" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <!-- Link Cliccabili -->
            <TextBlock FontSize="14" Margin="0,3,0,3">
                <Run x:Name="RunSito" Text="Sito : "/>
                <Hyperlink NavigateUri="https://federicosalis.it" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#00a8ff">
                    https://federicosalis.it
                </Hyperlink>
            </TextBlock>

            <TextBlock FontSize="14" Margin="0,3,0,3">
                <Run x:Name="RunBlog" Text="Blog : "/>
                <Hyperlink NavigateUri="https://blog.federicosalis.it/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#00a8ff">
                    https://blog.federicosalis.it/
                </Hyperlink>
            </TextBlock>

            <TextBlock FontSize="14" Margin="0,3,0,3">
                <Run x:Name="RunAltro" Text="Altro : "/>
                <Hyperlink NavigateUri="https://linktr.ee/federicosalis" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#00a8ff">
                    https://linktr.ee/federicosalis
                </Hyperlink>
            </TextBlock>

            <!-- Bottone OK Forzato stilisticamente -->
            <Button Width="100" Height="35" Margin="0,20,0,0" HorizontalAlignment="Right" Cursor="Hand" Click="BtnOk_Click" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#00a8ff" CornerRadius="5">
                            <TextBlock Text="OK" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>